# Copy to .env in this directory:  cp .env.example .env
# Then set real values. Never commit .env.

HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- Google Cloud SQL (PostgreSQL) — use this to run against GCP instead of SQLite ---
CLOUD_SQL_INSTANCE=YOUR_PROJECT_ID:YOUR_REGION:altitudedb1
CLOUD_SQL_DATABASE=altitude
CLOUD_SQL_USER=your_db_user
CLOUD_SQL_PASSWORD=your_db_password

# Laptop + Cloud SQL Auth Proxy to localhost:5432
CLOUD_SQL_USE_UNIX_SOCKET=false
CLOUD_SQL_HOST=127.0.0.1
CLOUD_SQL_PORT=5432

# On GCP (Cloud Run / GCE with connector), use instead:
# CLOUD_SQL_USE_UNIX_SOCKET=true
# (omit CLOUD_SQL_HOST or leave empty)

# CORS (frontend dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: only used if CLOUD_SQL_* above are NOT all set
# DATABASE_URL=sqlite+aiosqlite:///./altitude.db
