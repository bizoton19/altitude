# Copy to .env:  cp .env.example .env
# Never commit .env.

HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- Local database (default): SQLite file in this directory ---
DATABASE_URL=sqlite+aiosqlite:///./altitude.db

# CORS (frontend dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Optional: Google Cloud SQL (PostgreSQL) — only uncomment and fill if you
# are NOT using SQLite. All three must be set or the app keeps using SQLite.
# See CLOUD_SQL_SETUP.md
# ---------------------------------------------------------------------------
# CLOUD_SQL_INSTANCE=YOUR_PROJECT_ID:YOUR_REGION:altitudedb1
# CLOUD_SQL_DATABASE=altitude
# CLOUD_SQL_USER=your_db_user
# CLOUD_SQL_PASSWORD=your_db_password
# CLOUD_SQL_USE_UNIX_SOCKET=false
# CLOUD_SQL_HOST=127.0.0.1
# CLOUD_SQL_PORT=5432
# On GCP with Unix socket:
# CLOUD_SQL_USE_UNIX_SOCKET=true
